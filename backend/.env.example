# Configuración de InsForge API
# Estas credenciales sirven para asegurar el respaldo diario.
# Sustituye con los verdaderos valores proporcionados por InsForge
INSFORGE_PROJECT_ID=sustituir_por_el_id_del_proyecto
INSFORGE_API_KEY=sustituir_por_tu_api_key_secreta

# La URL de tu instancia de InsForge (si cambia)
INSFORGE_API_URL=https://api.insforge.com/api/v1
